# ==================================================================
# YPMG Lab Webapp - Environment Configuration
# ==================================================================
#
# ⚠️  SECURITY WARNING:
# - NEVER commit the .env file to git
# - Use strong, unique values for all secrets
# - Rotate credentials regularly
# - Use different values for each environment
#
# ==================================================================

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development

# ⚠️  CRITICAL: Generate a secure SECRET_KEY
# Command: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# Database (SQLite - Legacy)
# DATABASE_URI=instance/lab_data.db

# ==================================================================
# Azure SQL Database Configuration
# ==================================================================
# Server: ezeos.database.windows.net (West US 2)
# Architecture: Two databases for separation of concerns
#   - "users" database: User authentication and admin tables
#   - "ezeos" database: Sessions, form submissions, and audit logs
#
# IMPORTANT: Before connecting, you MUST:
#   1. Enable public network access in Azure Portal
#   2. Add your IP address to firewall rules
#   See docs/azure_sql_setup.md for detailed instructions
# ==================================================================

AZURE_SQL_SERVER=ezeos.database.windows.net
AZURE_SQL_USERS_DATABASE=users
AZURE_SQL_EZEOS_DATABASE=ezeos
AZURE_SQL_USERNAME=peepeepoopoo
AZURE_SQL_PASSWORD=your-secure-password-here
AZURE_SQL_DRIVER={ODBC Driver 17 for SQL Server}

# Admin
ADMIN_EMAIL=admin@ypmg.com

# Email Configuration (Microsoft 365)
# To get app password: https://account.microsoft.com/security
# Sign in > Security > Advanced security options > App passwords
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@ypmg.com
MAIL_PASSWORD=your-app-password-here
MAIL_DEFAULT_SENDER=your-email@ypmg.com

# Registration Settings
ALLOWED_EMAIL_DOMAIN=ypmg.com
CONFIRMATION_TOKEN_EXPIRY=3600
